OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your_api_key_here
MODEL_NAME=qwen-max

RETRIEVAL_MODE=arxiv
ARXIV_MAX_RESULTS=5

EVALUATE_WITH_LLM=false

LLM_TIMEOUT=120
MAX_GENERATE_DOCS=3
DOC_CONTENT_LIMIT=1000

LOG_LEVEL=INFO
LOG_FILE=logs/paper_agent.log

REASON_WITH_LLM=true
REASON_CONFIDENCE_THRESHOLD=0.75

CACHE_DIR=data/cache

PDF_MAX_CHARS=12000